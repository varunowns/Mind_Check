{
  "name": "mindcheck-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:client",
    "dev:client": "npm --workspace @mindcheck/client run dev",
    "dev:server": "npm --workspace @mindcheck/server run dev",
    "build": "npm-run-all build:shared build:server build:client",
    "build:shared": "npm --workspace @mindcheck/shared run build",
    "build:server": "npm --workspace @mindcheck/server run build",
    "build:client": "npm --workspace @mindcheck/client run build",
    "test": "npm-run-all test:shared test:server test:client",
    "test:shared": "npm --workspace @mindcheck/shared run test",
    "test:server": "npm --workspace @mindcheck/server run test",
    "test:client": "npm --workspace @mindcheck/client run test"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.2"
  }
}
